{
  "name": "tabby-docker-console",
  "version": "0.1.3",
  "description": "Remote Docker management panel for Tabby SSH sessions — containers, images, logs, stats and exec terminal over SSH",
  "keywords": [
    "tabby-plugin",
    "tabby",
    "docker",
    "ssh",
    "containers"
  ],
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "webpack --progress --color",
    "watch": "webpack --progress --color --watch",
    "install:tabby": "mkdir -p \"$HOME/Library/Application Support/tabby/plugins/node_modules/tabby-docker-console/dist\" && cp package.json \"$HOME/Library/Application Support/tabby/plugins/node_modules/tabby-docker-console/\" && cp dist/index.js \"$HOME/Library/Application Support/tabby/plugins/node_modules/tabby-docker-console/dist/\"",
    "prepublishOnly": "npm run build",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "author": "jeishod",
  "license": "MIT",
  "devDependencies": {
    "@angular/animations": "^14.0.0",
    "@angular/cdk": "^14.0.0",
    "@angular/common": "^14.0.0",
    "@angular/core": "^14.0.0",
    "@angular/forms": "^14.0.0",
    "@angular/platform-browser": "^14.0.0",
    "@ng-bootstrap/ng-bootstrap": "^13.0.0",
    "@types/node": "^18.0.0",
    "@types/webpack-env": "^1.18.0",
    "apply-loader": "^2.0.0",
    "css-loader": "^6.0.0",
    "ngx-toastr": "^15.0.0",
    "pug": "^2.0.4",
    "pug-loader": "^2.4.0",
    "rxjs": "^7.5.0",
    "sass": "^1.50.0",
    "sass-loader": "^13.0.0",
    "style-loader": "^3.0.0",
    "tabby-core": "^1.0.163",
    "tabby-settings": "^1.0.163",
    "tabby-ssh": "^1.0.163",
    "tabby-terminal": "^1.0.163",
    "ts-loader": "^9.4.0",
    "typescript": "~4.8.4",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.0"
  },
  "peerDependencies": {
    "@angular/core": ">=7.0.0",
    "tabby-core": ">=1.0.0",
    "tabby-ssh": ">=1.0.0"
  },
  "homepage": "https://github.com/Jeishod/tabby-docker-console#readme",
  "bugs": {
    "url": "https://github.com/Jeishod/tabby-docker-console/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jeishod/tabby-docker-console"
  }
}
